{
  "name": "@crawlee-cloud/cli",
  "version": "1.3.1",
  "description": "CLI for Crawlee Cloud - run and deploy Actors",
  "type": "module",
  "bin": {
    "crawlee-cloud": "dist/bin.js",
    "crc": "dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepack": "npm run clean && npm run build"
  },
  "keywords": [
    "crawlee",
    "cli",
    "apify",
    "scraper"
  ],
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "fs-extra": "^11.2.0",
    "inquirer": "^12.1.0",
    "ora": "^8.1.1",
    "table": "^6.9.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  },
  "files": [
    "dist"
  ],
  "preferGlobal": true,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crawlee-cloud/crawlee-cloud.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/crawlee-cloud/crawlee-cloud/issues"
  },
  "homepage": "https://crawlee.cloud"
}
