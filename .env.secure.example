# =============================================================================
# CRAWLEE CLOUD - SECURE PRODUCTION CONFIGURATION TEMPLATE
# =============================================================================
#
# ⚠️  SECURITY WARNING: This file contains secure configuration guidelines.
# DO NOT use values from docker-compose.yml or .env.example in production.
#
# Usage:
#   1. Copy this file to .env
#   2. Replace ALL placeholder values with actual secrets
#   3. Generate strong random secrets using commands provided
#   4. NEVER commit .env to version control
#   5. Validate configuration on startup (VALIDATE_CONFIG_ON_STARTUP=true)
#
# Last Updated: January 2025
# Review Date: 2025-01-20
# =============================================================================

# =============================================================================
# API SECRET (SEC-001)
# =============================================================================
# REQUIRED - No defaults allowed in production
# Minimum length: 32 characters (64+ recommended)
# This secret is used for authentication (JWT signing, internal service auth).
# Compromise = total platform access.
#
# Generate with: openssl rand -base64 64 | tr -d '\n'
# Rotate every: 90 days
#
API_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_64_DO_NOT_USE_DEFAULTS

# =============================================================================
# DATABASE CONFIGURATION (SEC-007)
# =============================================================================
# PostgreSQL connection with TLS enabled
# REQUIRED: Change default credentials
# REQUIRED: Enable SSL/TLS (sslmode=require)
#
# Security checklist:
# - [x] Changed from postgres:postgres defaults
# - [x] Password minimum 20 characters
# - [x] TLS/SSL enabled (sslmode=require or verify-full)
# - [x] Network access restricted to necessary IPs
# - [x] Connection pooling configured
#
# Generate password: openssl rand -base64 32 | tr -d '\n'
#
DATABASE_URL=postgresql://crawlee_user:STRONG_GENERATED_PASSWORD_HERE@database-host:5432/crawlee_cloud?sslmode=require

# Alternative: Use verify-full for maximum security (requires CA cert)
# DATABASE_URL=postgresql://crawlee_user:PASSWORD@host:5432/crawlee_cloud?sslmode=verify-full&sslrootcert=/path/to/ca.crt

# =============================================================================
# REDIS CONFIGURATION (SEC-007, SEC-017)
# =============================================================================
# Redis with TLS and authentication enabled
# Used for: queues, caching, logs (may contain sensitive data)
#
# Security checklist:
# - [x] Authentication enabled
# - [x] TLS enabled (rediss:// scheme)
# - [x] Dangerous commands disabled (FLUSHALL, CONFIG, etc.)
# - [x] Network isolation configured
#
# Generate password: openssl rand -base64 32 | tr -d '\n'
#
REDIS_URL=rediss://:STRONG_GENERATED_PASSWORD_HERE@redis-host:6380

# Optional: Non-TLS for development only (NOT for production)
# REDIS_URL=redis://:PASSWORD@localhost:6379

# =============================================================================
# S3-COMPATIBLE OBJECT STORAGE (SEC-007)
# =============================================================================
# Used for: datasets, key-value stores, Actor packages
# Supports: AWS S3, MinIO, DigitalOcean Spaces, etc.
#
# Security checklist:
# - [x] HTTPS endpoint only
# - [x] Access keys rotated regularly (every 90 days)
# - [x] IAM roles used instead of long-lived keys (when possible)
# - [x] Bucket versioning enabled
# - [x] Bucket policies configured (principle of least privilege)
#
# Generate access key: openssl rand -hex 20
# Generate secret key: openssl rand -base64 40 | tr -d '\n'
#

# AWS S3 (recommended)
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=crawlee-cloud-production
S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE  # Replace with actual IAM access key
S3_SECRET_KEY=REPLACE_WITH_ACTUAL_SECRET_KEY  # 40+ characters
S3_FORCE_PATH_STYLE=false

# Alternative: Self-hosted MinIO (ensure TLS is configured)
# S3_ENDPOINT=https://minio.yourdomain.com
# S3_REGION=us-east-1
# S3_BUCKET=crawlee-cloud
# S3_ACCESS_KEY=GENERATED_ACCESS_KEY_HERE
# S3_SECRET_KEY=GENERATED_SECRET_KEY_HERE
# S3_FORCE_PATH_STYLE=true

# =============================================================================
# CORS CONFIGURATION (SEC-008)
# =============================================================================
# CRITICAL: Restrict to specific domains only
# NEVER use { origin: true } or '*' in production
#
# Format: Comma-separated list of allowed origins (no wildcards)
#
CORS_ORIGINS=https://app.yourdomain.com,https://dashboard.yourdomain.com,https://api.yourdomain.com

# Optional: Allowed methods (default: GET,POST,PUT,DELETE,PATCH)
CORS_METHODS=GET,POST,PUT,DELETE,PATCH

# Optional: Allowed headers
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Optional: Credentials support (required for cookie-based auth)
CORS_CREDENTIALS=true

# =============================================================================
# NETWORK & TLS CONFIGURATION (SEC-014)
# =============================================================================
# API Server configuration
#
PORT=3000

# TLS/HTTPS (highly recommended for production)
# If using reverse proxy (nginx, Traefik), terminate TLS there
# If using direct TLS:
ENABLE_HTTPS=true
TLS_CERT_PATH=/path/to/fullchain.pem
TLS_KEY_PATH=/path/to/privkey.pem

# Security headers (Helmet.js)
ENABLE_HELMET=true
ENABLE_HSTS=true  # HTTP Strict Transport Security
HSTS_MAX_AGE=31536000  # 1 year
HSTS_INCLUDE_SUBDOMAINS=true

# =============================================================================
# RATE LIMITING (SEC-018)
# =============================================================================
# Protection against brute force and DoS attacks
#
ENABLE_RATE_LIMITING=true

# Global rate limit (requests per window)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000  # 1 minute

# Authentication endpoints (stricter limits)
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000  # 15 minutes

# =============================================================================
# ADMIN USER CONFIGURATION (SEC-007)
# =============================================================================
# Initial admin account created on first startup
# REQUIRED: Change these values
# RECOMMENDED: Disable after first login and use regular user accounts
#
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=STRONG_GENERATED_PASSWORD_HERE  # Minimum 16 characters

# Optional: Disable admin auto-creation (after first setup)
# CREATE_ADMIN_ON_STARTUP=false

# =============================================================================
# CONTAINER SECURITY (SEC-004, SEC-005, SEC-013)
# =============================================================================
# Runner configuration for Docker orchestration
#

# Docker connection
# WARNING: Docker socket access = root-level host access
# Consider: Docker API proxy, Docker-in-Docker, or Kubernetes Jobs
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Container security options
CONTAINER_SECURITY_ENABLED=true
CONTAINER_DROP_CAPABILITIES=true  # Drop all capabilities except required
CONTAINER_READONLY_ROOTFS=false  # Set to true if Actors support it
CONTAINER_NO_NEW_PRIVILEGES=true  # Prevent privilege escalation
CONTAINER_SECCOMP_PROFILE=default  # Or path to custom profile

# Resource limits (SEC-010)
DEFAULT_MEMORY_LIMIT=2048  # MB
DEFAULT_CPU_LIMIT=2.0  # CPU cores
MAX_MEMORY_LIMIT=8192  # Maximum allowed per run
MAX_CPU_LIMIT=4.0

# Timeouts (SEC-010)
DEFAULT_TIMEOUT=3600  # 1 hour (seconds)
MAX_TIMEOUT=86400  # 24 hours maximum

# Concurrent runs
MAX_CONCURRENT_RUNS=10

# Network isolation
CONTAINER_NETWORK_MODE=bridge  # Isolate containers
# CONTAINER_NETWORK_MODE=none  # No network access (strict)

# =============================================================================
# IMAGE SECURITY (SEC-012)
# =============================================================================
# Docker image verification and management
#
ENABLE_IMAGE_VERIFICATION=true
ENABLE_IMAGE_SIGNING=true  # Requires Docker Content Trust setup
ALLOWED_IMAGE_REGISTRIES=docker.io,ghcr.io,your-registry.com

# Optional: Image scanning
ENABLE_IMAGE_SCANNING=true
IMAGE_SCANNER=trivy  # Options: trivy, snyk
REJECT_HIGH_SEVERITY_VULNS=true

# =============================================================================
# LOGGING & MONITORING (SEC-011, SEC-017)
# =============================================================================
# Audit and security event logging
#
LOG_LEVEL=info  # Options: error, warn, info, debug (never use debug in prod)
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_PATH=/var/log/crawlee-cloud/audit.log

# Security: Don't log sensitive data
LOG_SANITIZE_SECRETS=true
LOG_SANITIZE_PATTERNS=password,token,secret,apikey,api_key

# Log retention
LOG_RETENTION_DAYS=90

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# =============================================================================
# SECRETS MANAGEMENT (SEC-006)
# =============================================================================
# Integration with external secrets management systems
#
# Options: vault, aws-secrets-manager, azure-keyvault, gcp-secret-manager
SECRETS_PROVIDER=vault

# HashiCorp Vault configuration
VAULT_ADDR=https://vault.yourdomain.com:8200
VAULT_TOKEN=s.XXXXXXXXXXXXXXXXXXXXXX  # Or use role-based auth
VAULT_NAMESPACE=crawlee-cloud
VAULT_SECRETS_PATH=secret/data/crawlee-cloud

# AWS Secrets Manager (alternative)
# SECRETS_PROVIDER=aws-secrets-manager
# AWS_REGION=us-east-1
# AWS_SECRETS_PREFIX=crawlee-cloud/

# =============================================================================
# INPUT VALIDATION (SEC-009, SEC-010)
# =============================================================================
# Strict input validation and bounds checking
#
ENABLE_INPUT_VALIDATION=true
STRICT_VALIDATION=true  # Reject requests with extra fields

# API parameter limits (prevent DoS)
MAX_LIMIT_PARAMETER=1000  # Maximum value for ?limit= parameter
DEFAULT_LIMIT=100
MAX_OFFSET_PARAMETER=1000000
MAX_BATCH_SIZE=1000  # Maximum items in batch operations

# Request size limits
MAX_REQUEST_SIZE=10485760  # 10MB (bytes)
MAX_JSON_PAYLOAD_SIZE=1048576  # 1MB

# =============================================================================
# SECURITY VALIDATION (SEC-001, SEC-007)
# =============================================================================
# Validate configuration security on startup
#
VALIDATE_CONFIG_ON_STARTUP=true
FAIL_ON_INSECURE_CONFIG=true

# Enforce secure configuration
ALLOW_WEAK_SECRETS=false  # Reject secrets < minimum length
ALLOW_DEFAULT_CREDENTIALS=false  # Reject known defaults
REQUIRE_TLS=true  # Require TLS for all external connections

# Security checks
CHECK_JWT_SECRET_STRENGTH=true
CHECK_DATABASE_TLS=true
CHECK_REDIS_AUTH=true
CHECK_S3_HTTPS=true
CHECK_CORS_CONFIG=true

# =============================================================================
# WEBHOOK SECURITY
# =============================================================================
# Secure webhook delivery
#
WEBHOOK_TIMEOUT=10000  # 10 seconds
WEBHOOK_MAX_RETRIES=3
WEBHOOK_VERIFY_SSL=true  # Verify SSL certificates
WEBHOOK_ALLOWED_HOSTS=  # Optional: comma-separated list of allowed domains

# Webhook payload signing (recommended)
WEBHOOK_SIGNING_ENABLED=true
WEBHOOK_SIGNING_SECRET=GENERATE_WITH_openssl_rand_-base64_32

# =============================================================================
# DEVELOPMENT vs PRODUCTION
# =============================================================================
# Environment indicator
#
NODE_ENV=production

# Feature flags for development
ENABLE_SWAGGER_UI=false  # Disable API documentation in production
ENABLE_DEBUG_ENDPOINTS=false  # Disable /debug/* endpoints
ENABLE_HOT_RELOAD=false

# =============================================================================
# BACKUP & DISASTER RECOVERY
# =============================================================================
# Backup configuration
#
ENABLE_AUTOMATED_BACKUPS=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM (cron format)
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=crawlee-cloud-backups
BACKUP_ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_-base64_32

# =============================================================================
# MAINTENANCE & UPDATES
# =============================================================================
# Security update notifications
#
CHECK_FOR_SECURITY_UPDATES=true
SECURITY_UPDATE_CHANNEL=stable

# Maintenance mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Platform under maintenance. Please try again later.

# =============================================================================
# AUTO-SCALER (security-relevant flags)
# =============================================================================
# Full scaler config lives in .env.example; the variables below carry real
# security implications and should stay OFF in production.
#
# SCALER_INSECURE_TLS — when true, every runner provisioned by the scaler
# boots with NODE_TLS_REJECT_UNAUTHORIZED=0. That disables certificate
# verification on every outbound HTTPS call from the runner: API, S3, image
# registries, and any actor scraping over HTTPS. MITM-vulnerable end-to-end.
# Leave false unless your runners must reach an internal CA / self-signed
# host they cannot otherwise trust, and you have compensating network
# controls. The API logs a startup warning when this is enabled.
SCALER_INSECURE_TLS=false

# METRICS_PUBLIC — when true, GET /metrics is unauthenticated. By default
# the endpoint is admin-only because it exposes process internals (Node
# heap, GC stats) and per-route HTTP counters that are useful for
# fingerprinting a deployment. Set to true only when your Prometheus
# scraper runs on a private network and cannot send an Authorization
# header. There is intentionally no equivalent flag for /v2/scaler/status.
METRICS_PUBLIC=false

# Cloud-init secrets caveat: when SCALER_PROVIDER=digitalocean, the user_data
# script that boots each runner contains DATABASE_URL, REDIS_URL, and any
# configured registry tokens in plaintext. user_data is readable from the
# DigitalOcean metadata service (http://169.254.169.254/metadata/v1/user-data)
# by anything running on the VM, including actor containers. Treat each
# runner as having full credentials, and consider firewalling the metadata
# IP from actor containers at the runner's docker network config.

# =============================================================================
# CONFIGURATION VALIDATION
# =============================================================================
# Before deploying, verify:
# - [ ] All REPLACE_WITH_* placeholders replaced
# - [ ] All secrets generated with secure random generation
# - [ ] TLS enabled for all connections (DATABASE_URL, REDIS_URL, S3_ENDPOINT)
# - [ ] CORS_ORIGINS restricted to specific domains
# - [ ] Default credentials changed (ADMIN_EMAIL, ADMIN_PASSWORD)
# - [ ] API_SECRET is 64+ characters
# - [ ] Rate limiting enabled
# - [ ] Security headers enabled (ENABLE_HELMET, ENABLE_HSTS)
# - [ ] VALIDATE_CONFIG_ON_STARTUP=true
# - [ ] SCALER_INSECURE_TLS=false (or omitted)
# - [ ] METRICS_PUBLIC=false (or omitted)
# - [ ] This file is NOT committed to version control
#
# Run validation: npm run security:validate-config
#
# =============================================================================
